# --- Postgres ---
POSTGRES_USER=events
POSTGRES_PASSWORD=change-me
POSTGRES_DB=events
# Both scraper and web build the connection string from the vars above.
# Inside docker-compose the host is the service name "db" (POSTGRES_HOST to override).

# --- LLM (provider-agnostic via OpenRouter) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Cheap model for bulk extraction; escalate only on parse failure.
LLM_MODEL_EXTRACT=google/gemini-2.0-flash-001
# Optional separate model for classification; falls back to extract model.
LLM_MODEL_CLASSIFY=
# Optional: sent as HTTP-Referer / X-Title for OpenRouter attribution.
OPENROUTER_APP_URL=https://events.example.org
OPENROUTER_APP_NAME=Jena Event Aggregator
