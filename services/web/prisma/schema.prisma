generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Source {
  id           String        @id
  name         String
  region       String
  enabled      Boolean       @default(false)
  lastRunAt    DateTime?     @map("last_run_at") @db.Timestamptz(6)
  lastOkAt     DateTime?     @map("last_ok_at") @db.Timestamptz(6)
  failCount    Int           @default(0) @map("fail_count")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  eventSources EventSource[]

  @@map("source")
}

model Venue {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  address   String?
  lat       Float?
  lng       Float?
  region    String?
  website   String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  events    Event[]

  @@unique([name, region])
  @@map("venue")
}

model Event {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  startsAt     DateTime      @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime?     @map("ends_at") @db.Timestamptz(6)
  allDay       Boolean       @default(false) @map("all_day")
  venueId      String?       @map("venue_id") @db.Uuid
  venue        Venue?        @relation(fields: [venueId], references: [id])
  categories   String[]
  tags         String[]
  priceMin     Decimal?      @map("price_min")
  priceMax     Decimal?      @map("price_max")
  currency     String        @default("EUR")
  url          String?
  ticketUrl    String?       @map("ticket_url")
  imageUrl     String?       @map("image_url")
  organizer    String?
  region       String?
  status       String        @default("active")
  dedupeHash   String        @unique @map("dedupe_hash")
  firstSeenAt  DateTime      @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt   DateTime      @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  eventSources EventSource[]

  @@map("event")
}

model EventSource {
  eventId     String   @map("event_id") @db.Uuid
  sourceId    String   @map("source_id")
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  sourceUrl   String?  @map("source_url")
  rawHash     String?  @map("raw_hash")
  extractedAt DateTime @default(now()) @map("extracted_at") @db.Timestamptz(6)

  @@id([eventId, sourceId])
  @@map("event_source")
}
