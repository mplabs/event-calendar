// Generated from db/migrations via `prisma db pull`. Do NOT hand-edit — CI (schema-drift) fails on drift.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Placeholder only — the real URL is built from POSTGRES_* in src/lib/db.ts
  // and injected via PrismaClient's datasources option at runtime.
  url      = "postgresql://placeholder"
}

model Source {
  id           String        @id
  name         String
  region       String
  enabled      Boolean       @default(false)
  lastRunAt    DateTime?     @map("last_run_at") @db.Timestamptz(6)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  eventSources EventSource[]

  @@map("source")
}

model Venue {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  address   String?
  region    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  events    Event[]

  @@unique([name, region])
  @@map("venue")
}

model Event {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  startsAt     DateTime      @map("starts_at") @db.Timestamptz(6)
  endsAt       DateTime?     @map("ends_at") @db.Timestamptz(6)
  allDay       Boolean       @default(false) @map("all_day")
  venueId      String?       @map("venue_id") @db.Uuid
  categories   String[]      @default([])
  tags         String[]      @default([])
  priceMin     Decimal?      @map("price_min") @db.Decimal
  priceMax     Decimal?      @map("price_max") @db.Decimal
  currency     String        @default("EUR")
  url          String?
  ticketUrl    String?       @map("ticket_url")
  imageUrl     String?       @map("image_url")
  organizer    String?
  region       String?
  status       String        @default("active")
  dedupeHash   String        @unique @map("dedupe_hash")
  firstSeenAt  DateTime      @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt   DateTime      @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  venue        Venue?        @relation(fields: [venueId], references: [id], onUpdate: NoAction)
  eventSources EventSource[]

  @@index([categories], type: Gin)
  @@index([startsAt])
  @@index([title(ops: raw("gin_trgm_ops"))], map: "event_title_trgm_idx", type: Gin)
  @@map("event")
}

model EventSource {
  eventId     String   @map("event_id") @db.Uuid
  sourceId    String   @map("source_id")
  sourceUrl   String?  @map("source_url")
  extractedAt DateTime @default(now()) @map("extracted_at") @db.Timestamptz(6)
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  source      Source   @relation(fields: [sourceId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([eventId, sourceId])
  @@map("event_source")
}
